<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <PlatformTarget>x64</PlatformTarget>
    <AssemblyName>DrumPracticeStudio</AssemblyName>
    <RootNamespace>DrumPracticeStudio</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="NAudio" Version="3.0.0-preview.16" />
    <PackageReference Include="NAudio.Wasapi" Version="3.0.0-preview.16" />
    <PackageReference Include="NAudio.WinMM" Version="3.0.0-preview.16" />
    <PackageReference Include="NAudio.Vst3" Version="3.0.0-preview.16" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="scripts\setup-demucs.ps1" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="tests\**\*.cs" />
  </ItemGroup>

</Project>
