                                                                                                           Foreground="#596170"
                                                                                                           FontSize="11"
                                                                                                           FontWeight="SemiBold" />
                                                                                            </Border>
                                                                                        </DataTemplate>
                                                                                    </GroupStyle.HeaderTemplate>
                                                                                </GroupStyle>
                                                                            </ComboBox.GroupStyle>
                                                                        </ComboBox>
                                                                        <TextBlock Text="{Binding ExternalVst3.Name}"
                                                                                   Foreground="{StaticResource TextSecondary}"
                                                                                   FontSize="9" TextWrapping="Wrap" />
                                                                        <Button Style="{StaticResource PrimaryButton}"
                                                                                Content="Abrir interfaz"
                                                                                Margin="0,4,0,0" HorizontalAlignment="Left"
                                                                                IsEnabled="{Binding CanOpenEditor}"
                                                                                Command="{Binding DataContext.OpenVstEffectEditorCommand,
                                                                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                CommandParameter="{Binding}"
                                                                                AutomationProperties.Name="Abrir interfaz del plugin VST3"
                                                                                AutomationProperties.AutomationId="OpenVstEffectEditorButton" />
                                                                        <Button Style="{StaticResource SecondaryButton}"
                                                                                Content="Preset VST3"
                                                                                Margin="0,3,0,0" HorizontalAlignment="Left"
                                                                                Command="{Binding DataContext.ChooseVstEffectPresetCommand,
                                                                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                CommandParameter="{Binding}" />
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="2" Margin="6,0">
                                                                        <TextBlock Text="MEZCLA" FontSize="9"
                                                                                   Foreground="{StaticResource TextSecondary}" />
                                                                        <Slider Minimum="0" Maximum="1"
                                                                                Value="{Binding Mix,
                                                                                                Mode=TwoWay,
                                                                                                UpdateSourceTrigger=PropertyChanged}" />
                                                                    </StackPanel>
                                                                    <WrapPanel Grid.Column="3" VerticalAlignment="Center">
                                                                        <Button Style="{StaticResource SecondaryButton}" Content="⇈"
                                                                                Padding="7,3"
                                                                                ToolTip="Mover al principio de la cadena"
                                                                                Command="{Binding DataContext.MoveBusEffectSlotUpCommand,
                                                                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                CommandParameter="{Binding}" />
                                                                        <Button Style="{StaticResource SecondaryButton}" Content="⇊"
                                                                                Padding="7,3" Margin="3,0,0,0"
                                                                                ToolTip="Mover al final de la cadena"
                                                                                Command="{Binding DataContext.MoveBusEffectSlotDownCommand,
                                                                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                CommandParameter="{Binding}" />
                                                                        <Button Style="{StaticResource SecondaryButton}" Content="×"
                                                                                Padding="7,3" Margin="3,0,0,0"
                                                                                Command="{Binding DataContext.RemoveBusEffectSlotCommand,
                                                                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                CommandParameter="{Binding}" />
                                                                    </WrapPanel>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Expander>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="Entrada MIDI" FontSize="16" FontWeight="SemiBold" />
                                <ComboBox ItemsSource="{Binding MidiDevices}" SelectedItem="{Binding SelectedMidiDevice}"
                                          Margin="0,10,0,0" HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}" Foreground="#151820" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <WrapPanel Margin="0,10,0,0" HorizontalAlignment="Right">
                                    <Button Style="{StaticResource SecondaryButton}" Content="Actualizar"
                                            Command="{Binding RefreshMidiCommand}" />
                                </WrapPanel>
                                <TextBlock Text="Sensibilidad de los pads" FontWeight="SemiBold" Margin="0,16,0,0" />
                                <Slider Minimum="0" Maximum="100"
                                        Value="{Binding MidiVelocitySensitivity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        Margin="0,8,0,0"
                                        AutomationProperties.AutomationId="MidiVelocitySensitivitySlider" />
                                <Grid Margin="0,3,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Menos sensible" Foreground="{StaticResource TextSecondary}" FontSize="11" />
                                    <TextBlock Grid.Column="1" Text="{Binding MidiVelocitySensitivityLabel}"
                                               Foreground="{StaticResource Accent}" FontWeight="SemiBold" FontSize="11" />
                                    <TextBlock Grid.Column="2" Text="Más sensible" HorizontalAlignment="Right"
                                               Foreground="{StaticResource TextSecondary}" FontSize="11" />
                                </Grid>
                                <TextBlock Text="{Binding MidiVelocityMonitor}" Foreground="{StaticResource TextSecondary}"
                                           TextWrapping="Wrap" Margin="0,7,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,18">
                            <StackPanel x:Name="VstInstrumentPanel">
                                <TextBlock Text="INSTRUMENTO VST3" Foreground="{StaticResource Accent}" FontSize="10" FontWeight="Bold" />
                                <TextBlock Text="{Binding ActiveDrumEngineLabel}" FontSize="19" FontWeight="SemiBold" Margin="0,6,0,3" />
                                <TextBlock Text="Usa Addictive Drums 2, Groove Agent u otro instrumento VST3 instalado sin extraer sus librerías protegidas."
                                           Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,14" />
                                <StackPanel>
                                    <ComboBox ItemsSource="{Binding Vst3Instruments}"
                                              SelectedItem="{Binding SelectedVstInstrument}"
                                              Background="#F4F6FA"
                                              Foreground="#151820"
                                              HorizontalAlignment="Stretch">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayLabel}" Foreground="#151820" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <Button Style="{StaticResource SecondaryButton}" Content="Buscar instrumentos"
                                            Margin="0,10,0,0" HorizontalAlignment="Right"
                                            Command="{Binding ScanVstInstrumentsCommand}" />
                                </StackPanel>
                                <TextBlock Text="KIT / PROGRAMA EXPUESTO POR EL VST3"
                                           Foreground="{StaticResource TextSecondary}" FontSize="10" FontWeight="Bold"
                                           Margin="0,14,0,6" />
                                <StackPanel>
                                    <ComboBox ItemsSource="{Binding Vst3Programs}"
                                              SelectedItem="{Binding SelectedVstProgram}"
                                              IsEnabled="{Binding HasVstPrograms}"
                                              HorizontalAlignment="Stretch"
                                              AutomationProperties.AutomationId="Vst3ProgramCombo">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayName}" Foreground="#151820" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                                <WrapPanel Margin="0,12,0,0">
                                    <Button Style="{StaticResource SecondaryButton}" Content="Cargar preset .vstpreset"
                                            Margin="0,0,8,8" Command="{Binding LoadVstPresetCommand}"
                                            IsEnabled="{Binding IsVstInstrumentLoaded}" />
                                    <Button Style="{StaticResource SecondaryButton}" Content="Abrir editor avanzado"
                                            Margin="0,0,8,8" Command="{Binding OpenVstEditorCommand}"
                                            IsEnabled="{Binding IsVstInstrumentLoaded}" />
                                    <Button Style="{StaticResource SecondaryButton}" Content="Pánico MIDI"
                                            Margin="0,0,8,8" Command="{Binding PanicVstCommand}"
                                            IsEnabled="{Binding IsVstInstrumentLoaded}" />
                                    <Button Style="{StaticResource SecondaryButton}" Content="Usar motor interno"
                                            Margin="0,0,8,8" Command="{Binding UseInternalDrumsCommand}" />
                                </WrapPanel>
                                <ProgressBar Height="5" Margin="0,6,0,8" IsIndeterminate="True"
                                             HorizontalAlignment="Stretch" ClipToBounds="True"
                                             Visibility="{Binding IsScanningVst, Converter={StaticResource BoolToVisibility}}" />
                                <TextBlock Text="{Binding VstStatus}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding VstAudioStatus}" Foreground="{StaticResource Accent}"
                                           TextWrapping="Wrap" Margin="0,5,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Perfil General Drums · inicial" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="Estas notas producen articulaciones, no nombres de archivos. MIDI Learn y perfiles por fabricante llegarán después."
                                           Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,5,0,16" />
                                <ItemsControl ItemsSource="{Binding MappingRows}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><UniformGrid Columns="2" /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#12161E" BorderBrush="{StaticResource Stroke}" BorderThickness="1"
                                                    CornerRadius="8" Padding="12" Margin="0,0,10,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="75" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding NoteLabel}" Foreground="{StaticResource Accent}" FontWeight="SemiBold" />
                                                    <TextBlock Grid.Column="1" Text="{Binding ArticulationLabel}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
