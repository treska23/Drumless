<Window x:Class="DrumPracticeStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="Drum Practice Studio"
        Width="1420"
        Height="900"
        MinWidth="240"
        MinHeight="140"
        WindowStartupLocation="Manual"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid Background="{StaticResource AppBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.22*" MinWidth="160" MaxWidth="224" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Navegación -->
        <Border Grid.Column="0" Background="#0F1218" BorderBrush="{StaticResource Stroke}" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="18,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <Border Width="42" Height="42" HorizontalAlignment="Left" CornerRadius="10" Background="{StaticResource Accent}">
                            <TextBlock Text="DS" Foreground="#15120D" FontWeight="Bold" FontSize="15"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="DRUM PRACTICE" FontWeight="Bold" FontSize="15" Margin="0,14,0,2" />
                        <TextBlock Text="STUDIO" Foreground="{StaticResource TextSecondary}" FontSize="11" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,28,0,0">
                        <Button Style="{StaticResource NavButton}" Content="●  Practicar"
                                Command="{Binding NavigateCommand}" CommandParameter="Practice" />
                        <Button Style="{StaticResource NavButton}" Content="▦  Librerías"
                                Command="{Binding NavigateCommand}" CommandParameter="Libraries" />
                        <Button Style="{StaticResource NavButton}" Content="♫  Pistas locales"
                                Command="{Binding NavigateCommand}" CommandParameter="Tracks" />
                        <Button Style="{StaticResource NavButton}" Content="▶  YouTube"
                                Command="{Binding NavigateCommand}" CommandParameter="YouTube" />
                        <Button Style="{StaticResource NavButton}" Content="⚙  Dispositivos"
                                Command="{Binding NavigateCommand}" CommandParameter="Settings" />
                    </StackPanel>

                    <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="13" Background="#151922">
                        <StackPanel>
                            <TextBlock Text="PROTOTIPO 0.1" Foreground="{StaticResource Accent}" FontSize="10" FontWeight="Bold" />
                            <TextBlock Text="Audio y MIDI locales" Margin="0,5,0,0" FontSize="12" />
                            <TextBlock Text="Sin secretos guardados" Foreground="{StaticResource TextSecondary}" FontSize="11" />
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- Área principal -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="70" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="{StaticResource Stroke}" BorderThickness="0,0,0,1" Background="#0D1016">
                <Grid Margin="28,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding StatusMessage}" FontSize="13" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="El controlador y el kit están desacoplados"
                                   Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,3,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#18251F" CornerRadius="8" Padding="12,7" Margin="0,0,10,0">
                            <TextBlock Text="{Binding MidiStatus}" Foreground="{StaticResource Success}" FontSize="11" />
                        </Border>
                        <Border Background="{StaticResource AccentDark}" CornerRadius="8" Padding="12,7">
                            <TextBlock Text="{Binding ActiveKitName}" Foreground="{StaticResource Accent}" FontWeight="SemiBold" FontSize="11" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Background="#3B2A12" BorderBrush="{StaticResource Accent}"
                    BorderThickness="0,0,0,1" Padding="18,10"
                    Visibility="{Binding IsAudioAlertVisible, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding AudioAlertMessage}" Foreground="{StaticResource Accent}"
                                   FontWeight="SemiBold" FontSize="13" />
                        <TextBlock Text="{Binding AudioAlertDetails}" Foreground="#F4D7A4"
                                   TextWrapping="Wrap" FontSize="11" Margin="0,3,12,0" />
                    </StackPanel>
                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                        <Button Style="{StaticResource SecondaryButton}" Content="Reintentar"
                                Command="{Binding RetryAudioOutputCommand}" Margin="0,0,8,0"
                                AutomationProperties.AutomationId="RetryAudioOutputButton" />
                        <Button Style="{StaticResource SecondaryButton}" Content="Ocultar"
                                Command="{Binding DismissAudioAlertCommand}" />
                    </WrapPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="2" Background="{StaticResource AppBackground}"
                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False">
                <Grid Margin="30,26,30,36">
                    <!-- PRACTICAR -->
                    <Grid Visibility="{Binding IsPracticePage, Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="330" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,22,0">
                            <TextBlock Text="Practicar" FontSize="30" FontWeight="SemiBold" />
                            <TextBlock Text="Elige una pista, carga un kit y empieza a tocar."
                                       Foreground="{StaticResource TextSecondary}" FontSize="14" Margin="0,5,0,22" />

                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="PISTA LOCAL" Foreground="{StaticResource Accent}" FontSize="10" FontWeight="Bold" />
                                        <TextBlock Text="{Binding CurrentTrackTitle}" FontSize="19" FontWeight="SemiBold" Margin="0,7,0,2" />
                                        <TextBlock Text="{Binding CurrentTrackSubtitle}" Foreground="{StaticResource TextSecondary}" FontSize="12" />
                                    </StackPanel>
                                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                        <Button Style="{StaticResource SecondaryButton}" Content="Anterior" Padding="11,8" Margin="0,0,8,0"
                                                Command="{Binding PreviousTrackCommand}"
                                                AutomationProperties.AutomationId="PreviousTrackButton" />
                                        <Button Style="{StaticResource SecondaryButton}" Content="−10 s" Padding="11,8" Margin="0,0,8,0"
                                                Command="{Binding SeekTrackCommand}" CommandParameter="-10" />
                                        <Button Style="{StaticResource PrimaryButton}" Content="{Binding PlayButtonLabel}" MinWidth="105"
                                                Command="{Binding ToggleTrackCommand}"
                                                AutomationProperties.AutomationId="TogglePlaybackButton" />
                                        <Button Style="{StaticResource SecondaryButton}" Content="Parar" Padding="11,8" Margin="8,0,8,0"
                                                Command="{Binding StopTrackCommand}"
                                                AutomationProperties.AutomationId="StopPlaybackButton" />
                                        <Button Style="{StaticResource SecondaryButton}" Content="Siguiente" Padding="11,8"
                                                Command="{Binding NextTrackCommand}"
                                                AutomationProperties.AutomationId="NextTrackButton" />
                                    </WrapPanel>

                                    <Slider Grid.Row="1" Grid.ColumnSpan="2" Height="16" Margin="0,14,0,3"
                                            Minimum="0"
                                            Maximum="{Binding TrackDurationSeconds, Mode=OneWay}"
                                            Value="{Binding TrackProgress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            IsMoveToPointEnabled="True"
                                            ToolTip="Arrastra o pulsa para avanzar y retroceder"
                                            AutomationProperties.Name="Posición de reproducción" />
                                    <Grid Grid.Row="2" Grid.ColumnSpan="2">
                                        <TextBlock Text="{Binding TrackPositionLabel}" Foreground="{StaticResource TextSecondary}" FontSize="11" />
                                        <TextBlock Text="{Binding TrackDurationLabel}" Foreground="{StaticResource TextSecondary}" FontSize="11" HorizontalAlignment="Right" />
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20" Background="#171C25">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="GRABAR LA MEZCLA FINAL" Foreground="{StaticResource Accent}"
                                                   FontSize="10" FontWeight="Bold" />
                                        <TextBlock Text="{Binding RecordingStatus}" Margin="0,7,18,0"
                                                   Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                        <Button Style="{StaticResource PrimaryButton}" Content="● Grabar"
                                                IsEnabled="{Binding CanStartOutputRecording}"
                                                Command="{Binding StartOutputRecordingCommand}"
                                                AutomationProperties.AutomationId="StartOutputRecordingButton" />
                                        <Button Style="{StaticResource SecondaryButton}" Content="■ Terminar"
                                                Margin="8,0,0,0" IsEnabled="{Binding CanStopOutputRecording}"
                                                Command="{Binding StopOutputRecordingCommand}"
                                                AutomationProperties.AutomationId="StopOutputRecordingButton" />
                                        <Button Style="{StaticResource SecondaryButton}" Content="▶ Última toma"
                                                Margin="8,0,0,0" IsEnabled="{Binding HasLastRecording}"
                                                Command="{Binding PlayLastRecordingCommand}"
                                                AutomationProperties.AutomationId="PlayLastRecordingButton" />
                                    </WrapPanel>
                                </Grid>
                            </Border>

                            <Grid Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Pads del kit" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="La altura del golpe MIDI controla la capa de velocidad."
                                               Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,3,0,0" />
                                </StackPanel>
                                <TextBlock Text="Haz clic para probar" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Foreground="{StaticResource TextSecondary}" FontSize="11" />
                            </Grid>

                            <ItemsControl ItemsSource="{Binding ActivePads}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="4" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Margin="0,0,10,10" Height="132"
                                                Command="{Binding DataContext.PlayPadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" Cursor="Hand" BorderThickness="0" Padding="0"
                                                AutomationProperties.Name="{Binding Name}"
                                                AutomationProperties.HelpText="{Binding MidiLabel}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="{Binding Accent}" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="PadRoot" Background="{TemplateBinding Background}" CornerRadius="12" Padding="15">
                                                                    <Grid>
                                                                        <StackPanel VerticalAlignment="Bottom">
                                                                            <TextBlock Text="{Binding ShortName}" Foreground="#101217" FontWeight="Bold" FontSize="14" />
                                                                            <TextBlock Text="{Binding MidiLabel}" Foreground="#5D4F40" FontSize="10" Margin="0,4,0,0" />
                                                                        </StackPanel>
                                                                        <Ellipse Width="10" Height="10" Fill="#66101217" HorizontalAlignment="Right" VerticalAlignment="Top" />
                                                                    </Grid>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <DataTrigger Binding="{Binding IsHit}" Value="True">
                                                                        <Setter TargetName="PadRoot" Property="Opacity" Value="0.55" />
                                                                    </DataTrigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="PadRoot" Property="Opacity" Value="0.86" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="KIT ACTIVO" Foreground="{StaticResource Accent}" FontSize="10" FontWeight="Bold" />
                                    <TextBlock Text="{Binding ActiveKitName}" FontSize="23" FontWeight="SemiBold" Margin="0,8,0,3" />
                                    <TextBlock Text="{Binding ActiveLibraryName}" Foreground="{StaticResource TextSecondary}" />
                                    <Border Height="1" Background="{StaticResource Stroke}" Margin="0,18" />
                                    <TextBlock Text="Cambiar de kit no cambia las notas asignadas a tu batería."
                                               TextWrapping="Wrap" Foreground="{StaticResource TextSecondary}" FontSize="12" />
                                    <Button Style="{StaticResource SecondaryButton}" Content="Elegir otro kit" Margin="0,16,0,0"
                                            Command="{Binding NavigateCommand}" CommandParameter="Libraries" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="IMPORTAR PISTA" FontSize="12" FontWeight="SemiBold" />
                                    <Button Style="{StaticResource PrimaryButton}" Content="Añadir pista original" Margin="0,12,0,8"
                                            Command="{Binding ImportTrackCommand}" CommandParameter="original" />
                                    <Button Style="{StaticResource SecondaryButton}" Content="Añadir pista ya drumless"
                                            Command="{Binding ImportTrackCommand}" CommandParameter="drumless" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="VOLUMEN DE PISTA" FontSize="11" Foreground="{StaticResource TextSecondary}" />
                                    <Slider Style="{StaticResource MixerFader}"
                                            Minimum="0" Maximum="1"
                                            Value="{Binding TrackVolume}"
                                            Margin="0,10,0,5"
                                            HorizontalAlignment="Center"
                                            PreviewMouseLeftButtonDown="OnMixerFaderPreviewMouseLeftButtonDown"
                                            AutomationProperties.Name="Volumen de pista"
                                            AutomationProperties.AutomationId="TrackVolumeFader" />
                                    <TextBlock Text="{Binding TrackVolume, StringFormat={}{0:P0}}"
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource Accent}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,7" />
                                    <TextBlock Text="La batería mantiene su nivel independiente."
                                               TextWrapping="Wrap" Foreground="{StaticResource TextSecondary}" FontSize="11" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="ANÁLISIS DE PISTA" Foreground="{StaticResource Accent}"
                                               FontSize="10" FontWeight="Bold" />
                                    <Button Style="{StaticResource SecondaryButton}" Content="Analizar tempo y estructura"
                                            Margin="0,10,0,8" IsEnabled="{Binding CanAnalyzeTempo}"
                                            Command="{Binding AnalyzeTempoCommand}"
                                            AutomationProperties.AutomationId="AnalyzeTempoButton" />
                                    <Button Style="{StaticResource PrimaryButton}"
                                            Content="Abrir letra y acordes"
                                            Margin="0,0,0,8"
                                            IsEnabled="{Binding HasTrack}"
                                            Command="{Binding OpenChordSheetWindowCommand}"
                                            AutomationProperties.AutomationId="OpenChordSheetButton" />
                                    <TextBlock Text="{Binding SongStructureStatus}"
                                               Foreground="{StaticResource TextSecondary}"
                                               TextWrapping="Wrap" FontSize="10"
                                               Margin="0,0,0,8" />
                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="BPM" Foreground="{StaticResource TextSecondary}" FontSize="10" />
                                            <TextBox Text="{Binding TempoBpm, UpdateSourceTrigger=LostFocus}"
                                                     AutomationProperties.AutomationId="TempoBpmTextBox" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="PRIMER PULSO (s)" Foreground="{StaticResource TextSecondary}" FontSize="10" />
                                            <TextBox Text="{Binding TempoFirstBeatSeconds, UpdateSourceTrigger=LostFocus}"
                                                     AutomationProperties.AutomationId="TempoFirstBeatTextBox" />
                                        </StackPanel>
                                    </Grid>
                                    <Expander Header="Mapa de tempo por tramos" Margin="0,10,0,0"
                                              IsExpanded="False"
                                              AutomationProperties.AutomationId="TempoMapExpander">
                                        <StackPanel Margin="0,8,0,0">
                                            <ListBox ItemsSource="{Binding TempoSegments}"
                                                     SelectedItem="{Binding SelectedTempoSegment}"
                                                     MaxHeight="150"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                     AutomationProperties.AutomationId="TempoSegmentList">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Summary}" TextWrapping="Wrap"
                                                                   Foreground="{StaticResource TextPrimary}" />
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                            <Grid Margin="0,7,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="INICIO DEL TRAMO (s)"
                                                               Foreground="{StaticResource TextSecondary}" FontSize="10" />
                                                    <TextBox Text="{Binding SelectedTempoSegment.StartSeconds,
                                                                           UpdateSourceTrigger=LostFocus}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="COMPÁS (pulsos)"
                                                               Foreground="{StaticResource TextSecondary}" FontSize="10" />
                                                    <TextBox Text="{Binding SelectedTempoSegment.BeatsPerBar,
                                                                           UpdateSourceTrigger=LostFocus}" />
                                                </StackPanel>
                                            </Grid>
                                            <WrapPanel Margin="0,7,0,0">
                                                <Button Style="{StaticResource SecondaryButton}" Content="Añadir tramo"
                                                        Command="{Binding AddTempoSegmentCommand}" />
                                                <Button Style="{StaticResource SecondaryButton}" Content="Quitar"
                                                        Margin="6,0,0,0"
                                                        Command="{Binding RemoveTempoSegmentCommand}" />
                                                <Button Style="{StaticResource SecondaryButton}" Content="↑"
                                                        Margin="6,0,0,0"
                                                        Command="{Binding MoveTempoSegmentUpCommand}" />
                                                <Button Style="{StaticResource SecondaryButton}" Content="↓"
                                                        Margin="6,0,0,0"
                                                        Command="{Binding MoveTempoSegmentDownCommand}" />
                                            </WrapPanel>
                                            <TextBlock Text="{Binding SelectedTempoSegment.SourceName,
                                                                      StringFormat=Fuente: {0}}"
                                                       Foreground="{StaticResource TextSecondary}" FontSize="10"
                                                       Margin="0,6,0,0" TextWrapping="Wrap" />
                                            <Button Style="{StaticResource SecondaryButton}" Content="Abrir fuente"
                                                    Margin="0,6,0,0" HorizontalAlignment="Left"
                                                    Command="{Binding OpenTempoSourceCommand}" />
                                        </StackPanel>
                                    </Expander>
                                    <Border BorderBrush="{StaticResource Stroke}" BorderThickness="1"
                                            CornerRadius="6" Padding="8" Margin="0,9,0,0"
                                            Visibility="{Binding HasTempoProposal,
                                                                 Converter={StaticResource BoolToVisibility}}">
                                        <StackPanel>
                                            <TextBlock Text="PROPUESTA DEL ANALIZADOR · NO APLICADA"
                                                       Foreground="{StaticResource Accent}" FontSize="10"
                                                       FontWeight="Bold" />
                                            <ItemsControl ItemsSource="{Binding ProposedTempoSegments}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Summary}" FontSize="10"
                                                                   Foreground="{StaticResource TextSecondary}"
                                                                   TextWrapping="Wrap" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Button Style="{StaticResource PrimaryButton}" Content="Aplicar propuesta"
                                                    Margin="0,7,0,0" HorizontalAlignment="Left"
                                                    Command="{Binding ApplyTempoProposalCommand}"
                                                    AutomationProperties.AutomationId="ApplyTempoProposalButton" />
                                        </StackPanel>
                                    </Border>
                                    <Expander Header="Buscar BPM en fuentes web" Margin="0,9,0,0"
                                              AutomationProperties.AutomationId="TempoSourcesExpander">
                                        <StackPanel Margin="0,8,0,0">
                                            <WrapPanel>
                                                <Button Style="{StaticResource SecondaryButton}" Content="Buscar fuentes"
                                                        Command="{Binding SearchTempoSourcesCommand}"
                                                        AutomationProperties.AutomationId="SearchTempoSourcesButton" />
                                                <Button Style="{StaticResource SecondaryButton}"
                                                        Content="Contrastar con Ollama"
                                                        Margin="6,0,0,0"
                                                        Command="{Binding ContrastTempoSourcesCommand}" />
                                            </WrapPanel>
                                            <ListBox ItemsSource="{Binding TempoSourceCandidates}"
                                                     SelectedItem="{Binding SelectedTempoSourceCandidate}"
                                                     MaxHeight="170" Margin="0,7,0,0"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="2,4">
                                                            <TextBlock Text="{Binding Bpm, StringFormat={}{0:0.##} BPM}"
                                                                       Foreground="{StaticResource Accent}"
                                                                       FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding Title}" TextWrapping="Wrap"
                                                                       Foreground="{StaticResource TextPrimary}" />
                                                            <TextBlock Text="{Binding Evidence}" TextWrapping="Wrap"
                                                                       Foreground="{StaticResource TextSecondary}"
                                                                       FontSize="10" />
                                                            <TextBlock Text="{Binding OllamaAssessment}" TextWrapping="Wrap"
                                                                       Foreground="{StaticResource TextSecondary}"
                                                                       FontStyle="Italic" FontSize="10" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                            <WrapPanel Margin="0,7,0,0">
                                                <Button Style="{StaticResource PrimaryButton}" Content="Aplicar al tramo"
                                                        Command="{Binding ApplyTempoSourceCommand}" />
                                                <Button Style="{StaticResource SecondaryButton}" Content="Abrir fuente"
                                                        Margin="6,0,0,0"
                                                        Command="{Binding OpenTempoSourceCommand}" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </Expander>
                                    <CheckBox Content="Activar claqueta sincronizada" Margin="0,10,0,5"
                                              IsChecked="{Binding MetronomeEnabled}"
                                              AutomationProperties.AutomationId="MetronomeEnabledCheckBox" />
                                    <TextBlock Text="VOLUMEN DE CLAQUETA" Foreground="{StaticResource TextSecondary}" FontSize="10" />
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                Margin="0,8,0,2">
                                        <Slider Style="{StaticResource MixerKnob}"
                                                Minimum="0" Maximum="1"
                                                Value="{Binding MetronomeVolume}"
                                                ToolTip="Arrastra a izquierda o derecha"
                                                AutomationProperties.AutomationId="MetronomeVolumeSlider" />
                                        <TextBlock Text="{Binding MetronomeVolume, StringFormat={}{0:P0}}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource Accent}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Margin="10,0,0,0" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding TempoStatus}" Foreground="{StaticResource TextSecondary}"
                                               TextWrapping="Wrap" FontSize="11" Margin="0,7,0,0" />
                                    <Button Style="{StaticResource SecondaryButton}" Content="Borrar análisis de esta pista"
                                            Margin="0,10,0,0" HorizontalAlignment="Left"
                                            Command="{Binding ClearAnalysisDataCommand}"
                                            AutomationProperties.AutomationId="ClearAnalysisDataButton" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="PRECISIÓN DE BATERÍA MIDI" Foreground="{StaticResource Accent}"
                                               FontSize="10" FontWeight="Bold" />
                                    <TextBlock Text="Compensa la latencia total antes de puntuar. La rejilla usa semicorcheas."
                                               Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"
                                               FontSize="11" Margin="0,7,0,7" />
                                    <Button Style="{StaticResource SecondaryButton}"
                                            Content="Analizar pista de batería de referencia"
                                            IsEnabled="{Binding CanAnalyzeDrumReference}"
                                            Command="{Binding AnalyzeDrumReferenceCommand}"
                                            HorizontalAlignment="Left"
                                            AutomationProperties.AutomationId="AnalyzeDrumReferenceButton" />
                                    <TextBlock Text="{Binding DrumReferenceStatus}"
                                               Foreground="{StaticResource TextSecondary}"
                                               TextWrapping="Wrap" FontSize="10" Margin="0,5,0,8" />
                                    <TextBlock Text="COMPENSACIÓN (ms)" Foreground="{StaticResource TextSecondary}" FontSize="10" />
                                    <TextBox Text="{Binding PerformanceLatencyCompensationMs, UpdateSourceTrigger=LostFocus}"
                                             AutomationProperties.AutomationId="PerformanceLatencyTextBox" />
                                    <WrapPanel Margin="0,9,0,0">
                                        <Button Style="{StaticResource PrimaryButton}" Content="Iniciar evaluación"
                                                IsEnabled="{Binding CanEvaluatePerformance}"
                                                Command="{Binding StartPerformanceEvaluationCommand}"
                                                AutomationProperties.AutomationId="StartPerformanceButton" />
                                        <Button Style="{StaticResource SecondaryButton}" Content="Finalizar"
                                                Margin="8,0,0,0"
                                                Command="{Binding FinishPerformanceEvaluationCommand}"
                                                AutomationProperties.AutomationId="FinishPerformanceButton" />
                                    </WrapPanel>
                                    <TextBlock Text="{Binding PerformanceResultText}" TextWrapping="Wrap"
                                               Margin="0,9,0,0" Foreground="{StaticResource TextSecondary}" />
                                    <TextBlock Text="HISTORIAL GUARDADO" Foreground="{StaticResource TextSecondary}"
                                               FontSize="10" FontWeight="Bold" Margin="0,12,0,3" />
                                    <TextBlock Text="{Binding PerformanceHistoryText}" TextWrapping="Wrap"
                                               Foreground="{StaticResource TextSecondary}" FontSize="11"
                                               AutomationProperties.AutomationId="PerformanceHistoryText" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- LIBRERÍAS -->
                    <Grid Visibility="{Binding IsLibrariesPage, Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="310" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,22,0">
                            <TextBlock Text="Librerías" FontSize="30" FontWeight="SemiBold" />
                            <TextBlock Text="Contenido instalado" Foreground="{StaticResource TextSecondary}" Margin="0,5,0,20" />
                            <ListBox ItemsSource="{Binding Libraries}" SelectedItem="{Binding SelectedLibrary}" ItemContainerStyle="{x:Null}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CardStyle}" Padding="15" Margin="0,0,0,10" Width="292">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="6" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Background="{Binding Accent}" CornerRadius="3" />
                                                <StackPanel Grid.Column="1" Margin="13,0,0,0">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                                                    <TextBlock Text="{Binding Category}" Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,3,0,0" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Text="{Binding SelectedLibrary.Name}" FontSize="27" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding SelectedLibrary.Description}" Foreground="{StaticResource TextSecondary}"
                                               FontSize="13" Margin="0,5,0,22" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <Button Style="{StaticResource SecondaryButton}" Content="Importar carpeta" Margin="0,0,8,0"
                                            Command="{Binding ImportSoundFolderCommand}" />
                                    <Button Style="{StaticResource PrimaryButton}" Content="Importar ZIP"
                                            Command="{Binding ImportSoundLibraryCommand}" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Seleccionar una librería carga automáticamente su primer kit."
                                       Foreground="{StaticResource Success}" FontSize="11" Margin="0,-14,0,18" />
                            <TextBlock Text="Puedes importar el ZIP descargado directamente o una carpeta ya descomprimida. Se reconocen kick/bombo, snare/caja, hihat abierto o cerrado, tom agudo o grave, crash y ride. Las etiquetas soft, medium, hard o velNN crean capas de fuerza."
                                       Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,-8,0,18"
                                       TextWrapping="Wrap" />

                            <ItemsControl ItemsSource="{Binding SelectedLibrary.Kits}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="92" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Background="{Binding Accent}" Width="72" Height="72" CornerRadius="14" HorizontalAlignment="Left">
                                                    <TextBlock Text="KIT" Foreground="#17130C" FontSize="16" FontWeight="Bold"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="20" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextSecondary}"
                                                               TextWrapping="Wrap" Margin="0,4,16,0" />
                                                    <TextBlock Text="{Binding PadCountLabel}" Foreground="{Binding Accent}" FontSize="11" Margin="0,7,0,0" />
                                                </StackPanel>
                                                <Button Grid.Column="2" Style="{StaticResource PrimaryButton}" Content="Cargar kit" VerticalAlignment="Center"
                                                        Command="{Binding DataContext.ActivateKitCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                                <StackPanel>
                                    <TextBlock Text="Personalizar el kit activo" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Text="Sustituye un pad por un WAV. Si el kit es de fábrica, se creará una copia en Mis sonidos."
                                               Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,5,0,15" />
                                    <ItemsControl ItemsSource="{Binding ActivePads}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,8" Padding="11,8"
                                                        Command="{Binding DataContext.ImportSampleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="＋ " Foreground="{Binding Accent}" FontWeight="Bold" />
                                                        <TextBlock Text="{Binding Name}" />
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- PISTAS -->
                    <StackPanel Visibility="{Binding IsTracksPage, Converter={StaticResource BoolToVisibility}}">
                        <Grid Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Biblioteca y playlists" FontSize="30" FontWeight="SemiBold" />
                                <TextBlock Text="Tus pistas externas siguen registradas y las versiones generadas aparecen automáticamente."
                                           Foreground="{StaticResource TextSecondary}" Margin="0,5,0,0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Style="{StaticResource PrimaryButton}" Content="Importar original" Margin="0,0,10,0"
                                        Command="{Binding ImportTrackCommand}" CommandParameter="original" />
                                <Button Style="{StaticResource SecondaryButton}" Content="Añadir pista ya drumless"
                                        Command="{Binding ImportTrackCommand}" CommandParameter="drumless" />
                            </StackPanel>
                        </Grid>

                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16" Background="#141923">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="CARPETA PARA PISTAS GENERADAS" Foreground="{StaticResource Accent}" FontSize="10" FontWeight="Bold" />
                                    <TextBlock Text="{Binding OutputFolderPath}" Margin="0,7,18,0" TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding OutputFolderPath}"
                                               AutomationProperties.AutomationId="OutputFolderPathText" />
                                    <TextBlock Text="Cambiarla no mueve ni elimina las pistas anteriores."
                                               Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,5,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Content="Elegir carpeta" Margin="0,0,8,0"
                                        Command="{Binding ChooseOutputFolderCommand}" VerticalAlignment="Center"
                                        AutomationProperties.AutomationId="ChooseOutputFolderButton" />
                                <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Content="Escanear ahora"
                                        Command="{Binding RescanLibraryCommand}" VerticalAlignment="Center"
                                        AutomationProperties.AutomationId="RescanLibraryButton" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="PISTA CARGADA" Foreground="{StaticResource Accent}" FontSize="10" FontWeight="Bold" />
                                    <TextBlock Text="{Binding CurrentTrackTitle}" FontSize="21" FontWeight="SemiBold" Margin="0,7,0,3" />
                                    <TextBlock Text="{Binding CurrentTrackSubtitle}" Foreground="{StaticResource TextSecondary}" />
                                </StackPanel>
                                <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Content="Crear mezcla de stems"
                                        Command="{Binding CreateDrumlessCommand}" IsEnabled="{Binding CanCreateDrumless}"
                                        VerticalAlignment="Center"
                                        AutomationProperties.AutomationId="CreateStemMixButton" />
                                <Border Grid.Row="1" Grid.ColumnSpan="2" BorderBrush="{StaticResource Stroke}"
                                        BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,14,0,0">
                                    <StackPanel>
                                        <TextBlock Text="CONSERVAR EN EL ARCHIVO FINAL"
                                                   Foreground="{StaticResource TextSecondary}" FontSize="10"
                                                   FontWeight="Bold" />
                                        <WrapPanel Margin="0,8,0,0">
                                            <CheckBox Content="Batería" IsChecked="{Binding KeepDrums}"
                                                      Margin="0,0,18,6" AutomationProperties.AutomationId="KeepDrumsCheckBox" />
                                            <CheckBox Content="Bajo" IsChecked="{Binding KeepBass}"
                                                      Margin="0,0,18,6" AutomationProperties.AutomationId="KeepBassCheckBox" />
                                            <CheckBox Content="Voz" IsChecked="{Binding KeepVocals}"
                                                      Margin="0,0,18,6" AutomationProperties.AutomationId="KeepVocalsCheckBox" />
                                            <CheckBox Content="Guitarra" IsChecked="{Binding KeepGuitar}"
                                                      Margin="0,0,18,6" AutomationProperties.AutomationId="KeepGuitarCheckBox" />
                                            <CheckBox Content="Piano y teclados" IsChecked="{Binding KeepPiano}"
                                                      Margin="0,0,18,6" AutomationProperties.AutomationId="KeepPianoCheckBox" />
                                            <CheckBox Content="Otros" IsChecked="{Binding KeepOther}"
                                                      Margin="0,0,0,6" AutomationProperties.AutomationId="KeepOtherCheckBox" />
                                        </WrapPanel>
                                        <TextBlock Text="{Binding StemSelectionSummary}" Foreground="{StaticResource Accent}"
                                                   FontWeight="SemiBold" Margin="0,3,0,0" />
                                        <TextBlock Text="Demucs separa seis grupos: batería, bajo, voz, guitarra, piano/teclados y otros. Puedes conservar cualquier combinación."
                                                   Foreground="{StaticResource TextSecondary}" FontSize="11"
                                                   TextWrapping="Wrap" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="3.5*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="1.8*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="16">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Biblioteca" FontSize="20" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding LibrarySummary}" Foreground="{StaticResource TextSecondary}" FontSize="11" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <WrapPanel HorizontalAlignment="Right">
                                                <Button x:Name="LoadLibrarySelectionButton"
                                                        Style="{StaticResource PrimaryButton}" Content="▶"
                                                        Padding="9,6" Margin="0,0,5,0" IsEnabled="False"
                                                        Click="OnLoadLibrarySelectionClick"
                                                        ToolTip="Cargar la pista seleccionada"
                                                        AutomationProperties.AutomationId="LoadLibrarySelectionButton" />
                                                <Button x:Name="AddLibrarySelectionButton"
                                                        Style="{StaticResource SecondaryButton}" Content="＋"
                                                        Padding="9,6" Margin="0,0,5,0" IsEnabled="False"
                                                        Click="OnAddLibrarySelectionToPlaylistClick"
                                                        ToolTip="Añadir las pistas seleccionadas a la playlist activa"
                                                        AutomationProperties.AutomationId="AddLibrarySelectionButton" />
                                                <Button x:Name="RemoveLibrarySelectionButton"
                                                        Style="{StaticResource SecondaryButton}" Content="✕"
                                                        Padding="9,6" IsEnabled="False"
                                                        Click="OnRemoveLibrarySelectionClick"
                                                        ToolTip="Quitar registros de la biblioteca; no elimina archivos"
                                                        AutomationProperties.AutomationId="RemoveLibrarySelectionButton" />
                                            </WrapPanel>
                                            <TextBlock x:Name="LibrarySelectionSummary" Text="0 seleccionadas"
                                                       Foreground="{StaticResource TextSecondary}" FontSize="10"
                                                       Margin="0,3,0,0" HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBox Text="{Binding LibrarySearchText, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Buscar por nombre, carpeta o tipo"
                                             Margin="0,0,0,7"
                                             AutomationProperties.Name="Buscar en la biblioteca"
                                             AutomationProperties.AutomationId="LibrarySearchTextBox" />
                                    <ComboBox ItemsSource="{Binding LibrarySortOptions}"
                                              SelectedItem="{Binding SelectedLibrarySortOption}"
                                              Margin="0,0,0,9"
                                              AutomationProperties.Name="Orden de la biblioteca"
                                              AutomationProperties.AutomationId="LibrarySortComboBox">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Label}" Foreground="#151820" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <ListBox x:Name="TrackLibraryList" ItemsSource="{Binding VisibleTracks}"
                                             SelectedItem="{Binding SelectedLibraryTrack}"
                                             SelectionMode="Extended"
                                             SelectionChanged="OnLibrarySelectionChanged"
                                             MaxHeight="430" AutomationProperties.AutomationId="TrackLibraryList"
                                             HorizontalContentAlignment="Stretch"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             PreviewMouseLeftButtonDown="OnLibraryDragStart"
                                             PreviewMouseMove="OnLibraryPreviewMouseMove">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Padding" Value="0" />
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{StaticResource Stroke}" BorderThickness="0,0,0,1" Padding="5,9">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding Title}" />
                                                        <TextBlock Text="ARCHIVO NO ENCONTRADO"
                                                                   Foreground="#FF7B7B" FontSize="10" FontWeight="Bold"
                                                                   Margin="0,3,0,0"
                                                                   Visibility="{Binding IsMissing, Converter={StaticResource BoolToVisibility}}"
                                                                   AutomationProperties.AutomationId="MissingTrackBadge" />
                                                        <WrapPanel Margin="0,3,0,0">
                                                            <TextBlock Text="{Binding VariantLabel}" Foreground="{StaticResource Accent}" FontSize="10" />
                                                            <TextBlock Text=" · " Foreground="{StaticResource TextSecondary}" FontSize="10" />
                                                            <TextBlock Text="{Binding DateAddedLabel}" Foreground="{StaticResource TextSecondary}" FontSize="10" />
                                                        </WrapPanel>
                                                        <TextBlock Text="{Binding Path}" Foreground="{StaticResource TextSecondary}" FontSize="10"
                                                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding Path}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="16">
                                <DockPanel LastChildFill="True">
                                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="PLAYLIST EN EDICIÓN" Foreground="{StaticResource Accent}"
                                                       FontSize="10" FontWeight="Bold" />
                                            <TextBlock Text="{Binding SelectedPlaylist.Name, TargetNullValue=Sin playlist}"
                                                       FontSize="24" FontWeight="SemiBold" Margin="0,4,0,2" />
                                            <TextBlock Text="{Binding SelectedPlaylistSummary}"
                                                       Foreground="{StaticResource TextSecondary}" FontSize="11" />
                                            <TextBlock Text="Arrastra aquí desde la biblioteca o reordena las filas. Doble clic reproduce."
                                                       Foreground="{StaticResource TextSecondary}" FontSize="11"
                                                       TextWrapping="Wrap" Margin="0,3,0,0" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                                Content="Abrir ventana flotante" Padding="10,7"
                                                Click="OnOpenPlaylistWindowClick"
                                                AutomationProperties.AutomationId="OpenPlaylistWindowButton" />
                                    </Grid>
                                    <Grid DockPanel.Dock="Top" Margin="0,0,0,9">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding PlaylistItemSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,0,9,0"
                                                 ToolTip="Buscar dentro de la playlist"
                                                 AutomationProperties.Name="Buscar en la playlist"
                                                 AutomationProperties.AutomationId="PlaylistItemSearchTextBox" />
                                        <StackPanel Grid.Column="1">
                                            <WrapPanel HorizontalAlignment="Right">
                                                <Button x:Name="PlayPlaylistSelectionButton"
                                                        Style="{StaticResource PrimaryButton}" Content="▶"
                                                        Padding="9,6" Margin="0,0,5,0" IsEnabled="False"
                                                        Click="OnPlayPlaylistSelectionClick"
                                                        ToolTip="Reproducir el elemento seleccionado"
                                                        AutomationProperties.AutomationId="PlayPlaylistSelectionButton" />
                                                <Button x:Name="MovePlaylistSelectionUpButton"
                                                        Style="{StaticResource SecondaryButton}" Content="↑"
                                                        Padding="8,6" Margin="0,0,5,0" IsEnabled="False"
                                                        Click="OnMovePlaylistSelectionUpClick"
                                                        ToolTip="Subir el elemento seleccionado"
                                                        AutomationProperties.AutomationId="MovePlaylistSelectionUpButton" />
                                                <Button x:Name="MovePlaylistSelectionDownButton"
                                                        Style="{StaticResource SecondaryButton}" Content="↓"
                                                        Padding="8,6" Margin="0,0,5,0" IsEnabled="False"
                                                        Click="OnMovePlaylistSelectionDownClick"
                                                        ToolTip="Bajar el elemento seleccionado"
                                                        AutomationProperties.AutomationId="MovePlaylistSelectionDownButton" />
                                                <Button x:Name="RemovePlaylistSelectionButton"
                                                        Style="{StaticResource SecondaryButton}" Content="✕"
                                                        Padding="8,6" IsEnabled="False"
                                                        Click="OnRemovePlaylistSelectionClick"
                                                        ToolTip="Quitar los elementos seleccionados; no elimina los orígenes"
                                                        AutomationProperties.AutomationId="RemovePlaylistSelectionButton" />
                                            </WrapPanel>
                                            <TextBlock x:Name="PlaylistItemSelectionSummary" Text="0 seleccionados"
                                                       Foreground="{StaticResource TextSecondary}" FontSize="10"
                                                       Margin="0,3,0,0" HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Grid>
                                    <ListBox x:Name="PlaylistItemList" ItemsSource="{Binding VisiblePlaylistItems}"
                                             SelectedItem="{Binding SelectedPlaylistItem}"
                                             SelectionMode="Extended"
                                             SelectionChanged="OnPlaylistSelectionChanged"
                                             MinHeight="390" MaxHeight="540"
                                             AutomationProperties.AutomationId="PlaylistTrackList"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.CanContentScroll="False"
                                             HorizontalContentAlignment="Stretch"
                                             AllowDrop="True" PreviewMouseLeftButtonDown="OnPlaylistDragStart"
                                             PreviewMouseMove="OnPlaylistPreviewMouseMove" Drop="OnPlaylistDrop"
                                             PreviewMouseWheel="OnPlaylistMouseWheel"
                                             MouseDoubleClick="OnPlaylistItemDoubleClick">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{StaticResource Stroke}" BorderThickness="0,0,0,1" Padding="6,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="36" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="☰" Foreground="{StaticResource TextSecondary}"
                                                                   FontSize="18" VerticalAlignment="Center" />
                                                        <StackPanel Grid.Column="1" Margin="5,0,12,0">
                                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                                       FontSize="15" TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding AvailabilityLabel}" Foreground="{StaticResource Accent}"
                                                                       FontSize="11" Margin="0,2,0,0" />
                                                            <TextBlock Text="{Binding Detail}" Foreground="{StaticResource TextSecondary}"
                                                                       FontSize="10" TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Border>

                            <Border Grid.Column="4" Style="{StaticResource CardStyle}" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Playlists" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="EDITAR UNA PLAYLIST" Foreground="{StaticResource TextSecondary}"
                                               FontSize="10" FontWeight="Bold" Margin="0,10,0,0" />
                                    <TextBlock Text="El selector elige dónde añadir y ordenar pistas. No cambia la mezcla por sí solo."
                                               Foreground="{StaticResource TextSecondary}" FontSize="11"
                                               TextWrapping="Wrap" Margin="0,4,0,0" />
                                    <TextBox Text="{Binding PlaylistSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,7,0,6"
                                             ToolTip="Buscar playlist por nombre"
                                             AutomationProperties.Name="Buscar playlists"
                                             AutomationProperties.AutomationId="PlaylistSearchTextBox" />
                                    <ListBox ItemsSource="{Binding VisiblePlaylists}"
                                             SelectedItem="{Binding SelectedPlaylist}"
                                             MaxHeight="120" Margin="0,0,0,8"
                                             HorizontalContentAlignment="Stretch"
                                             AutomationProperties.AutomationId="PlaylistSelector">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}" Padding="4,3"
                                                           TextTrimming="CharacterEllipsis" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <TextBox Text="{Binding PlaylistNameDraft, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Nombre para crear o renombrar" Margin="0,0,0,8"
                                             AutomationProperties.AutomationId="PlaylistNameTextBox" />
                                    <WrapPanel Margin="0,0,0,12">
                                        <Button Style="{StaticResource PrimaryButton}" Content="＋" Padding="11,7" Margin="0,0,6,6"
                                                Command="{Binding CreatePlaylistCommand}"
                                                ToolTip="Crear una playlist"
                                                AutomationProperties.AutomationId="NewPlaylistButton" />
                                        <Button Style="{StaticResource SecondaryButton}" Content="✎" Padding="11,7" Margin="0,0,6,6"
                                                Command="{Binding RenamePlaylistCommand}"
                                                ToolTip="Renombrar la playlist seleccionada"
                                                AutomationProperties.AutomationId="RenamePlaylistButton" />
                                        <Button Style="{StaticResource SecondaryButton}" Content="✕" Padding="11,7" Margin="0,0,0,6"
                                                Command="{Binding DeletePlaylistCommand}"
                                                ToolTip="Eliminar la playlist; no borra archivos"
                                                AutomationProperties.AutomationId="DeletePlaylistButton" />
                                    </WrapPanel>

                                    <TextBlock Text="COLA DE REPRODUCCIÓN" Foreground="{StaticResource TextSecondary}"
                                               FontSize="10" FontWeight="Bold" />
                                    <TextBlock Text="Marca una o varias playlists para combinarlas. Si no marcas ninguna, se usa la playlist que editas."
                                               Foreground="{StaticResource TextSecondary}" FontSize="11"
                                               TextWrapping="Wrap" Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding MixedPlaylistSummary}" Foreground="{StaticResource TextSecondary}"
                                               FontSize="11" TextWrapping="Wrap" Margin="0,5,0,7" />
                                    <Border BorderBrush="{StaticResource Stroke}" BorderThickness="1" CornerRadius="6"
                                            Padding="7,4" Margin="0,0,0,7">
                                        <ScrollViewer MaxHeight="105" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding Playlists}"
                                                          AutomationProperties.AutomationId="PlaylistMixList">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsIncludedInMix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  Margin="0,4" AutomationProperties.Name="{Binding Name}">
                                                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                                        </CheckBox>
