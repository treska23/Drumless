<Application x:Class="DrumPracticeStudio.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:infrastructure="clr-namespace:DrumPracticeStudio.Infrastructure">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <infrastructure:SliderValueToAngleConverter x:Key="SliderValueToAngle" />

        <SolidColorBrush x:Key="AppBackground" Color="#0B0D12" />
        <SolidColorBrush x:Key="PanelBackground" Color="#11141B" />
        <SolidColorBrush x:Key="CardBackground" Color="#181C25" />
        <SolidColorBrush x:Key="CardHover" Color="#202633" />
        <SolidColorBrush x:Key="Stroke" Color="#2B3240" />
        <SolidColorBrush x:Key="TextPrimary" Color="#F4F6FA" />
        <SolidColorBrush x:Key="TextSecondary" Color="#9DA6B5" />
        <SolidColorBrush x:Key="Accent" Color="#FFB548" />
        <SolidColorBrush x:Key="AccentDark" Color="#3B2B14" />
        <SolidColorBrush x:Key="Success" Color="#62D3A4" />
        <SolidColorBrush x:Key="ComboBackground" Color="#F4F6FA" />
        <SolidColorBrush x:Key="ComboForeground" Color="#151820" />
        <SolidColorBrush x:Key="ComboDisabledBackground" Color="#D9DDE5" />
        <SolidColorBrush x:Key="ComboDisabledForeground" Color="#596170" />

        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="{StaticResource AppBackground}" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Foreground,
                                               RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}}"
                             Value="{StaticResource ComboForeground}">
                    <Setter Property="Foreground" Value="{StaticResource ComboForeground}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Foreground,
                                               RelativeSource={RelativeSource AncestorType={x:Type ComboBoxItem}}}"
                             Value="{StaticResource ComboForeground}">
                    <Setter Property="Foreground" Value="{StaticResource ComboForeground}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource Stroke}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="#15120D" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="17,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.86" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.68" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.38" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#252B37" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        </Style>

        <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Padding" Value="14,11" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0F1218" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource Stroke}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,9" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource ComboBackground}" />
            <Setter Property="Foreground" Value="{StaticResource ComboForeground}" />
            <Setter Property="BorderBrush" Value="{StaticResource Stroke}" />
            <Setter Property="Padding" Value="9,7" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{StaticResource ComboDisabledBackground}" />
                    <Setter Property="Foreground" Value="{StaticResource ComboDisabledForeground}" />
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource ComboBackground}" />
            <Setter Property="Foreground" Value="{StaticResource ComboForeground}" />
            <Setter Property="Padding" Value="9,7" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#FFD491" />
                    <Setter Property="Foreground" Value="{StaticResource ComboForeground}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource Accent}" />
                    <Setter Property="Foreground" Value="{StaticResource ComboForeground}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{StaticResource ComboDisabledBackground}" />
                    <Setter Property="Foreground" Value="{StaticResource ComboDisabledForeground}" />
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="{StaticResource Accent}" />
        </Style>

        <Style x:Key="MixerFader" TargetType="Slider">
            <Setter Property="Orientation" Value="Vertical" />
            <Setter Property="IsDirectionReversed" Value="False" />
            <Setter Property="IsMoveToPointEnabled" Value="True" />
            <Setter Property="Height" Value="150" />
            <Setter Property="Width" Value="48" />
            <Setter Property="SmallChange" Value="0.01" />
            <Setter Property="LargeChange" Value="0.05" />
            <Setter Property="Cursor" Value="SizeNS" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Border Background="#0F1218"
                                BorderBrush="{StaticResource Stroke}"
                                BorderThickness="1"
                                CornerRadius="9"
                                Padding="5">
                            <Grid>
                                <Border Width="6"
                                        Margin="0,8"
                                        Background="#303746"
                                        CornerRadius="3"
                                        HorizontalAlignment="Center" />
                                <Track x:Name="PART_Track"
                                       Margin="0,8"
                                       Orientation="Vertical"
                                       Minimum="{TemplateBinding Minimum}"
                                       Maximum="{TemplateBinding Maximum}"
                                       Value="{TemplateBinding Value}"
                                       IsDirectionReversed="{TemplateBinding IsDirectionReversed}">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Background="Transparent"
                                                      BorderThickness="0"
                                                      Focusable="False"
                                                      IsHitTestVisible="False"
                                                      Opacity="0" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Width="36" Height="19">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border Background="#E8ECF4"
                                                            BorderBrush="#727C8E"
                                                            BorderThickness="1"
                                                            CornerRadius="4">
                                                        <Grid>
                                                            <Border Height="2"
                                                                    Margin="5,0"
                                                                    Background="{StaticResource Accent}"
                                                                    VerticalAlignment="Center"
                                                                    CornerRadius="1" />
                                                        </Grid>
                                                    </Border>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Background="Transparent"
                                                      BorderThickness="0"
                                                      Focusable="False"
                                                      IsHitTestVisible="False"
                                                      Opacity="0" />
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.42" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MixerKnob" TargetType="Slider">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="IsMoveToPointEnabled" Value="True" />
            <Setter Property="Width" Value="68" />
            <Setter Property="Height" Value="68" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Width="68" Height="68">
                            <Ellipse Margin="4"
                                     Fill="#171C25"
                                     Stroke="#596170"
                                     StrokeThickness="2" />
                            <Ellipse Margin="11"
                                     Fill="#222936"
                                     Stroke="#303746"
                                     StrokeThickness="1" />
                            <Border Width="3"
                                    Height="23"
                                    Margin="0,8,0,0"
                                    Background="{StaticResource Accent}"
                                    CornerRadius="1.5"
                                    VerticalAlignment="Top"
                                    RenderTransformOrigin="0.5,1">
                                <Border.RenderTransform>
                                    <RotateTransform>
                                        <RotateTransform.Angle>
                                            <MultiBinding Converter="{StaticResource SliderValueToAngle}">
                                                <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Value" />
                                                <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Minimum" />
                                                <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Maximum" />
                                            </MultiBinding>
                                        </RotateTransform.Angle>
                                    </RotateTransform>
                                </Border.RenderTransform>
                            </Border>
                            <Ellipse Width="9" Height="9"
                                     Fill="{StaticResource Accent}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
                            <Track x:Name="PART_Track"
                                   Margin="5,0"
                                   Orientation="Horizontal"
                                   Opacity="0">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}"
                                                  Background="Transparent"
                                                  BorderThickness="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="12" Height="68" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}"
                                                  Background="Transparent"
                                                  BorderThickness="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
