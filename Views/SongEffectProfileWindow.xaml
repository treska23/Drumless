<Window x:Class="DrumPracticeStudio.Views.SongEffectProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sonido de la canción"
        Width="980" Height="760"
        MinWidth="760" MinHeight="560"
        Background="{StaticResource AppBackground}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="Preparar sonido para esta canción"
                       FontSize="26" FontWeight="SemiBold" />
            <TextBlock Text="El modelo local de Ollama sólo puede elegir efectos VST3 instalados. Input 1 es guitarra mono e input 2 es voz mono. Nada se aplica sin tu confirmación."
                       Foreground="{StaticResource TextSecondary}"
                       TextWrapping="Wrap" Margin="0,6,0,12" />
            <ProgressBar Height="5" IsIndeterminate="True"
                         Visibility="{Binding IsAnalyzingSongEffects, Converter={StaticResource BoolToVisibility}}" />
            <TextBlock Text="{Binding SongEffectStatus}"
                       Foreground="{StaticResource Accent}"
                       TextWrapping="Wrap" Margin="0,9,0,0" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14"
                        Visibility="{Binding HasSavedSongEffectProfile, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="CONFIGURACIÓN GUARDADA"
                                   Foreground="{StaticResource Accent}"
                                   FontWeight="Bold" FontSize="11" />
                        <TextBlock Text="{Binding SavedSongEffectProfile.Name}"
                                   FontSize="20" FontWeight="SemiBold" Margin="0,5,0,2" />
                        <TextBlock Text="{Binding SavedSongEffectProfile.Summary}"
                                   Foreground="{StaticResource TextSecondary}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <StackPanel Visibility="{Binding HasProposedSongEffectProfile, Converter={StaticResource BoolToVisibility}}">
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="PROPUESTA PENDIENTE DE CONFIRMACIÓN"
                                       Foreground="{StaticResource Accent}"
                                       FontWeight="Bold" FontSize="11" />
                            <TextBlock Text="{Binding ProposedSongEffectProfile.TrackTitle}"
                                       FontSize="21" FontWeight="SemiBold" Margin="0,5,0,3" />
                            <TextBlock>
                                <Run Text="{Binding ProposedSongEffectProfile.Artist}" />
                                <Run Text=" · " />
                                <Run Text="{Binding ProposedSongEffectProfile.SongTitle}" />
                            </TextBlock>
                            <TextBlock Text="{Binding ProposedSongEffectProfile.Summary}"
                                       Foreground="{StaticResource TextSecondary}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ProposedSongEffectProfile.OllamaModel, StringFormat=Modelo local: {0}}"
                                       Foreground="{StaticResource TextSecondary}" Margin="0,7,0,0" />
                        </StackPanel>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding ProposedSongEffectProfile.Guitar.InputLabel}"
                                           FontSize="19" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ProposedSongEffectProfile.Guitar.Description}"
                                           Foreground="{StaticResource TextSecondary}"
                                           TextWrapping="Wrap" Margin="0,4,0,12" />
                                <ItemsControl ItemsSource="{Binding ProposedSongEffectProfile.Guitar.Slots}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource Stroke}" BorderThickness="0,1,0,0"
                                                    Padding="0,10">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Detail}" TextWrapping="Wrap"
                                                               Foreground="{StaticResource TextSecondary}" />
                                                    <TextBlock Text="{Binding AppliedConfiguration}"
                                                               TextWrapping="Wrap" FontSize="11"
                                                               Foreground="{StaticResource Success}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding ProposedSongEffectProfile.Voice.InputLabel}"
                                           FontSize="19" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ProposedSongEffectProfile.Voice.Description}"
                                           Foreground="{StaticResource TextSecondary}"
                                           TextWrapping="Wrap" Margin="0,4,0,12" />
                                <ItemsControl ItemsSource="{Binding ProposedSongEffectProfile.Voice.Slots}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource Stroke}" BorderThickness="0,1,0,0"
                                                    Padding="0,10">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Detail}" TextWrapping="Wrap"
                                                               Foreground="{StaticResource TextSecondary}" />
                                                    <TextBlock Text="{Binding AppliedConfiguration}"
                                                               TextWrapping="Wrap" FontSize="11"
                                                               Foreground="{StaticResource Success}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource PrimaryButton}"
                        Content="Analizar efectos"
                        Command="{Binding AnalyzeSongEffectsCommand}"
                        AutomationProperties.AutomationId="AnalyzeSongEffectsButton" />
                <Button Style="{StaticResource SecondaryButton}"
                        Content="Cancelar" Margin="8,0,0,0"
                        Command="{Binding CancelSongEffectAnalysisCommand}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Style="{StaticResource PrimaryButton}"
                        Content="Aplicar y guardar"
                        IsEnabled="{Binding HasProposedSongEffectProfile}"
                        Command="{Binding ApplySongEffectProfileCommand}"
                        AutomationProperties.AutomationId="ApplySongEffectsButton" />
                <Button Style="{StaticResource SecondaryButton}"
                        Content="Cerrar" Margin="8,0,0,0" Click="OnCloseClick" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
