<Window x:Class="DrumPracticeStudio.Views.ChordSheetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Letra y acordes · Drum Practice Studio"
        Width="1380" Height="820"
        MinWidth="960" MinHeight="620"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#252B37" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="BorderBrush" Value="{StaticResource Stroke}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7,7,0,0"
                                Padding="{TemplateBinding Padding}"
                                Margin="0,0,4,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabRoot"
                                        Property="Background"
                                        Value="{StaticResource AccentDark}" />
                                <Setter Property="Foreground"
                                        Value="{StaticResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabRoot" Property="Opacity" Value="0.84" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding CurrentTrackTitle}"
                               FontSize="22" FontWeight="SemiBold" />
                    <TextBlock x:Name="HeaderHelpText"
                               Text="Navega, selecciona la letra y los acordes y pulsa «Extraer selección». El contenido se guarda solo en este equipo."
                               Foreground="{StaticResource TextSecondary}"
                               TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                    <CheckBox Content="Seguir reproducción"
                              IsChecked="{Binding IsChordSheetFollowEnabled}"
                              VerticalAlignment="Center" Margin="0,0,12,0" />
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="A−"
                            Padding="8,5"
                            ToolTip="Reducir texto"
                            AutomationProperties.AutomationId="DecreaseChordSheetZoomButton"
                            Command="{Binding DecreaseChordSheetZoomCommand}" />
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="{Binding ChordSheetViewerZoomLabel}"
                            Padding="8,5"
                            MinWidth="58"
                            Margin="5,0"
                            ToolTip="Restablecer zoom"
                            AutomationProperties.AutomationId="ResetChordSheetZoomButton"
                            Command="{Binding ResetChordSheetZoomCommand}" />
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="A+"
                            Padding="8,5"
                            ToolTip="Ampliar texto"
                            AutomationProperties.AutomationId="IncreaseChordSheetZoomButton"
                            Command="{Binding IncreaseChordSheetZoomCommand}" />
                    <TextBlock x:Name="HeaderModeText"
                               Text="Marcas manuales de cambio sin límite"
                               Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="BrowserColumn" Width="1.08*" MinWidth="420" />
                <ColumnDefinition x:Name="WorkspaceGapColumn" Width="12" />
                <ColumnDefinition x:Name="EditorColumn" Width="0.92*" MinWidth="380" />
            </Grid.ColumnDefinitions>

            <Border x:Name="BrowserPane" Style="{StaticResource CardStyle}" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="AddressBox"
                                 KeyDown="OnAddressKeyDown"
                                 AutomationProperties.AutomationId="ChordSheetAddressBox" />
                        <Button Grid.Column="2" Style="{StaticResource SecondaryButton}"
                                Content="Abrir" Click="OnNavigateClick" />
                        <Button Grid.Column="4" Style="{StaticResource PrimaryButton}"
                                Content="Extraer selección"
                                Click="OnExtractClick"
                                AutomationProperties.AutomationId="ExtractChordSheetButton" />
                    </Grid>
                    <wv2:WebView2 x:Name="ChordWebView"
                                  Grid.Row="2"
                                  DefaultBackgroundColor="#0B0D12"
                                  Loaded="OnWebViewLoaded"
                                  AutomationProperties.AutomationId="ChordSheetWebView" />
                    <TextBlock x:Name="BrowserStatus"
                               Grid.Row="3"
                               Text="Preparando navegador…"
                               Foreground="{StaticResource TextSecondary}"
                               TextWrapping="Wrap" Margin="2,8,2,0" />
                </Grid>
            </Border>

            <Border x:Name="EditorPane" Grid.Column="2" Style="{StaticResource CardStyle}" Padding="12">
                <TabControl x:Name="ChordWorkspaceTabs"
                            Background="Transparent"
                            BorderThickness="0"
                            SelectionChanged="OnChordWorkspaceTabSelectionChanged">
                    <TabItem Header="OPCIONES">
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding ChordSheetStatus}"
                                           Foreground="{StaticResource TextSecondary}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Style="{StaticResource SecondaryButton}"
                                        Content="Buscar de nuevo"
                                        Margin="8,0,0,0"
                                        Command="{Binding SearchChordSheetSourcesCommand}" />
                            </Grid>
                            <ListBox Grid.Row="2"
                                     ItemsSource="{Binding ChordSheetSourceCandidates}"
                                     SelectedItem="{Binding SelectedChordSheetSource}"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     AutomationProperties.AutomationId="ChordSheetSourceList">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4,6">
                                            <TextBlock Text="{Binding Title}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding SourceName}"
                                                       Foreground="{StaticResource Accent}"
                                                       FontSize="11" />
                                            <TextBlock Text="{Binding Evidence}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="48" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <WrapPanel Grid.Row="3" Margin="0,8,0,0">
                                <Button Style="{StaticResource PrimaryButton}"
                                        Content="Procesar seleccionada"
                                        Click="OnProcessCandidateClick"
                                        AutomationProperties.AutomationId="ProcessChordSheetCandidateButton" />
                                <Button Style="{StaticResource SecondaryButton}"
                                        Content="Abrir para comprobar"
                                        Margin="8,0,0,0"
                                        Command="{Binding OpenChordSheetSourceCommand}" />
                            </WrapPanel>
                        </Grid>
                    </TabItem>
                    <TabItem x:Name="FollowTab"
                             Header="SEGUIR"
                             AutomationProperties.AutomationId="ChordSheetFollowTab">
                        <ListBox x:Name="ChordLineList"
                                 Margin="0,10,0,0"
                                 ItemsSource="{Binding ChordSheetLines}"
                                 SelectedItem="{Binding SelectedChordSheetLine}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.CanContentScroll="False"
                                 PreviewMouseWheel="OnChordLineListPreviewMouseWheel"
                                 AutomationProperties.AutomationId="ChordSheetLineList">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="8,4" />
                                    <Setter Property="Margin" Value="0,1" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource AccentDark}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Text}"
                                               FontFamily="Consolas"
                                               FontSize="{Binding DataContext.ChordSheetViewerFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Chords">
                                                        <Setter Property="Foreground" Value="{StaticResource Accent}" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Section">
                                                        <Setter Property="Foreground" Value="{StaticResource Success}" />
                                                        <Setter Property="FontWeight" Value="Bold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </TabItem>
                    <TabItem x:Name="MarkersTab"
                             Header="MARCAS"
                             AutomationProperties.AutomationId="ChordSheetMarkersTab">
                        <Grid Margin="0,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.35*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="0.65*" MinWidth="300" />
                                </Grid.ColumnDefinitions>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Selecciona la primera línea que debe mostrarse al llegar a la marca."
                                               Foreground="{StaticResource TextSecondary}"
                                               TextWrapping="Wrap" />
                                    <ListBox Grid.Row="2"
                                             ItemsSource="{Binding ChordSheetLines}"
                                             SelectedItem="{Binding SelectedChordSheetLine}"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             AutomationProperties.AutomationId="ChordSheetMarkerTargetLineList">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Padding" Value="7,4" />
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <Border x:Name="MarkerLabel"
                                                            Visibility="Collapsed"
                                                            Background="{StaticResource AccentDark}"
                                                            Padding="6,3"
                                                            Margin="0,0,0,3">
                                                        <TextBlock Text="{Binding ViewSwitchLabel}"
                                                                   Foreground="{StaticResource Accent}"
                                                                   FontSize="10" />
                                                    </Border>
                                                    <TextBlock Text="{Binding Text}"
                                                               FontFamily="Consolas"
                                                               FontSize="15"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsViewSwitchTarget}" Value="True">
                                                        <Setter TargetName="MarkerLabel" Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                                <Border Grid.Column="2"
                                        Background="#141A23"
                                        BorderBrush="{StaticResource Stroke}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="EDITAR MARCAS"
                                                   Foreground="{StaticResource Accent}"
                                                   FontWeight="SemiBold" />
                                        <WrapPanel Grid.Row="1" Margin="0,8,0,0">
                                            <TextBox Text="{Binding ChordSheetViewSwitchTimeText, UpdateSourceTrigger=LostFocus}"
                                                     Width="82"
                                                     ToolTip="Segundos, m:ss o h:mm:ss"
                                                     AutomationProperties.AutomationId="ChordSheetViewSwitchTime" />
                                            <Button Style="{StaticResource SecondaryButton}"
                                                    Content="Usar posición actual"
                                                    Margin="6,0,0,0"
                                                    Command="{Binding UseCurrentChordSheetViewSwitchTimeCommand}" />
                                            <Button Style="{StaticResource PrimaryButton}"
                                                    Content="Añadir"
                                                    Margin="6,0,0,0"
                                                    Command="{Binding SetChordSheetViewSwitchCommand}"
                                                    AutomationProperties.AutomationId="SetChordSheetViewSwitchButton" />
                                        </WrapPanel>
                                        <ListBox Grid.Row="3"
                                                 ItemsSource="{Binding ChordSheetViewportMarkers}"
                                                 SelectedItem="{Binding SelectedChordSheetViewportMarker}"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 AutomationProperties.AutomationId="ChordSheetViewportMarkerList">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Summary}"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding Summary}" />
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        <StackPanel Grid.Row="4" Margin="0,8,0,0">
                                            <TextBlock Text="{Binding ChordSheetViewportMarkers.Count, StringFormat={}{0} marcas configuradas}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="11" />
                                            <WrapPanel Margin="0,6,0,0">
                                                <Button Style="{StaticResource SecondaryButton}"
                                                        Content="Mover a línea"
                                                        IsEnabled="{Binding HasChordSheetViewSwitch}"
                                                        Command="{Binding MoveSelectedChordSheetViewportMarkerCommand}" />
                                                <Button Style="{StaticResource SecondaryButton}"
                                                        Content="Quitar"
                                                        Margin="6,0,0,0"
                                                        IsEnabled="{Binding HasChordSheetViewSwitch}"
                                                        Command="{Binding ClearChordSheetViewSwitchCommand}" />
                                                <Button Style="{StaticResource SecondaryButton}"
                                                        Content="Quitar todas"
                                                        Margin="6,0,0,0"
                                                        IsEnabled="{Binding HasChordSheetViewSwitch}"
                                                        Command="{Binding ClearAllChordSheetViewSwitchesCommand}" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>
                    <TabItem Header="EDITAR TEXTO">
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBox Text="{Binding ChordSheetTextDraft, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     TextWrapping="NoWrap"
                                     AutomationProperties.AutomationId="ChordSheetEditor" />
                            <WrapPanel Grid.Row="1" Margin="0,8,0,0">
                                <Button Style="{StaticResource PrimaryButton}"
                                        Content="Procesar y guardar"
                                        Command="{Binding SaveChordSheetTextCommand}" />
                                <Button Style="{StaticResource SecondaryButton}"
                                        Content="Importar archivo"
                                        Margin="8,0,0,0"
                                        Command="{Binding ImportChordSheetCommand}" />
                                <Button Style="{StaticResource SecondaryButton}"
                                        Content="Desvincular hoja"
                                        Margin="8,0,0,0"
                                        Command="{Binding ClearChordSheetCommand}" />
                            </WrapPanel>
                        </Grid>
                    </TabItem>
                    <TabItem Header="ESTRUCTURA">
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding SongStructureStatus}"
                                       Foreground="{StaticResource TextSecondary}"
                                       TextWrapping="Wrap" />
                            <ListBox Grid.Row="2"
                                     ItemsSource="{Binding SongSections}"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="85" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="70" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding StartSeconds, StringFormat={}{0:0.0} s}"
                                                       FontFamily="Consolas"
                                                       Foreground="{StaticResource Accent}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Label}" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Confidence, StringFormat={}{0:P0}}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       HorizontalAlignment="Right" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</Window>
