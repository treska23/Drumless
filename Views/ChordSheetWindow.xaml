<Window x:Class="DrumPracticeStudio.Views.ChordSheetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Letra y acordes · Drum Practice Studio"
        Width="1380" Height="820"
        MinWidth="960" MinHeight="620"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#252B37" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="BorderBrush" Value="{StaticResource Stroke}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7,7,0,0"
                                Padding="{TemplateBinding Padding}"
                                Margin="0,0,4,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabRoot"
                                        Property="Background"
                                        Value="{StaticResource AccentDark}" />
                                <Setter Property="Foreground"
                                        Value="{StaticResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabRoot" Property="Opacity" Value="0.84" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding CurrentTrackTitle}"
                               FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="Navega, selecciona la letra y los acordes y pulsa «Extraer selección». El contenido se guarda solo en este equipo."
                               Foreground="{StaticResource TextSecondary}"
                               TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                    <CheckBox Content="Seguir reproducción"
                              IsChecked="{Binding IsChordSheetFollowEnabled}"
                              VerticalAlignment="Center" Margin="0,0,12,0" />
                    <TextBlock Text="Un solo cambio automático por canción"
                               Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.08*" MinWidth="420" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="0.92*" MinWidth="380" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="AddressBox"
                                 KeyDown="OnAddressKeyDown"
                                 AutomationProperties.AutomationId="ChordSheetAddressBox" />
                        <Button Grid.Column="2" Style="{StaticResource SecondaryButton}"
                                Content="Abrir" Click="OnNavigateClick" />
                        <Button Grid.Column="4" Style="{StaticResource PrimaryButton}"
                                Content="Extraer selección"
                                Click="OnExtractClick"
                                AutomationProperties.AutomationId="ExtractChordSheetButton" />
                    </Grid>
                    <wv2:WebView2 x:Name="ChordWebView"
                                  Grid.Row="2"
                                  DefaultBackgroundColor="#0B0D12"
                                  Loaded="OnWebViewLoaded"
                                  AutomationProperties.AutomationId="ChordSheetWebView" />
                    <TextBlock x:Name="BrowserStatus"
                               Grid.Row="3"
                               Text="Preparando navegador…"
                               Foreground="{StaticResource TextSecondary}"
                               TextWrapping="Wrap" Margin="2,8,2,0" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="12">
                <TabControl Background="Transparent" BorderThickness="0">
                    <TabItem Header="OPCIONES">
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding ChordSheetStatus}"
                                           Foreground="{StaticResource TextSecondary}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Style="{StaticResource SecondaryButton}"
                                        Content="Buscar de nuevo"
                                        Margin="8,0,0,0"
                                        Command="{Binding SearchChordSheetSourcesCommand}" />
                            </Grid>
                            <ListBox Grid.Row="2"
                                     ItemsSource="{Binding ChordSheetSourceCandidates}"
                                     SelectedItem="{Binding SelectedChordSheetSource}"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     AutomationProperties.AutomationId="ChordSheetSourceList">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4,6">
                                            <TextBlock Text="{Binding Title}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding SourceName}"
                                                       Foreground="{StaticResource Accent}"
                                                       FontSize="11" />
                                            <TextBlock Text="{Binding Evidence}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="48" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <WrapPanel Grid.Row="3" Margin="0,8,0,0">
                                <Button Style="{StaticResource PrimaryButton}"
                                        Content="Procesar seleccionada"
                                        Click="OnProcessCandidateClick"
                                        AutomationProperties.AutomationId="ProcessChordSheetCandidateButton" />
                                <Button Style="{StaticResource SecondaryButton}"
                                        Content="Abrir para comprobar"
                                        Margin="8,0,0,0"
                                        Command="{Binding OpenChordSheetSourceCommand}" />
                            </WrapPanel>
                        </Grid>
                    </TabItem>
                    <TabItem Header="SEGUIR">
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding ChordSheetStatus}"
                                       Foreground="{StaticResource TextSecondary}"
                                       TextWrapping="Wrap" />
                            <Border Grid.Row="1"
                                    Margin="0,8,0,0"
                                    Padding="10"
                                    Background="#141A23"
                                    BorderBrush="{StaticResource Stroke}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="MARCA ÚNICA DE CAMBIO"
                                               Foreground="{StaticResource Accent}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Escribe el tiempo o usa la posición actual; después selecciona abajo la primera línea de la parte inferior."
                                               Foreground="{StaticResource TextSecondary}"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,8" />
                                    <WrapPanel>
                                        <TextBlock Text="Tiempo"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0" />
                                        <TextBox Text="{Binding ChordSheetViewSwitchTimeText, UpdateSourceTrigger=LostFocus}"
                                                 Width="78"
                                                 ToolTip="Segundos, m:ss o h:mm:ss"
                                                 AutomationProperties.AutomationId="ChordSheetViewSwitchTime" />
                                        <Button Style="{StaticResource SecondaryButton}"
                                                Content="Usar posición actual"
                                                Margin="8,0,0,0"
                                                Command="{Binding UseCurrentChordSheetViewSwitchTimeCommand}" />
                                        <Button Style="{StaticResource PrimaryButton}"
                                                Content="Aplicar a línea seleccionada"
                                                Margin="8,0,0,0"
                                                Command="{Binding SetChordSheetViewSwitchCommand}"
                                                AutomationProperties.AutomationId="SetChordSheetViewSwitchButton" />
                                        <Button Style="{StaticResource SecondaryButton}"
                                                Content="Quitar marca"
                                                Margin="8,0,0,0"
                                                IsEnabled="{Binding HasChordSheetViewSwitch}"
                                                Command="{Binding ClearChordSheetViewSwitchCommand}" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                            <ListBox x:Name="ChordLineList"
                                     Grid.Row="3"
                                     ItemsSource="{Binding ChordSheetLines}"
                                     SelectedItem="{Binding SelectedChordSheetLine}"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     PreviewMouseWheel="OnChordLineListPreviewMouseWheel"
                                     AutomationProperties.AutomationId="ChordSheetLineList">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="8,4" />
                                        <Setter Property="Margin" Value="0,1" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentDark}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <Border x:Name="ViewSwitchMarker"
                                                    Visibility="Collapsed"
                                                    Background="{StaticResource AccentDark}"
                                                    BorderBrush="{StaticResource Accent}"
                                                    BorderThickness="0,1,0,0"
                                                    Padding="8,5"
                                                    Margin="0,2,0,5">
                                                <TextBlock Text="{Binding ViewSwitchLabel}"
                                                           Foreground="{StaticResource Accent}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                            <TextBlock Text="{Binding Text}"
                                                       FontFamily="Consolas"
                                                       FontSize="17"
                                                       TextWrapping="NoWrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource TextPrimary}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Kind}" Value="Chords">
                                                                <Setter Property="Foreground"
                                                                        Value="{StaticResource Accent}" />
                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Kind}" Value="Section">
                                                                <Setter Property="Foreground"
                                                                        Value="{StaticResource Success}" />
                                                                <Setter Property="FontWeight" Value="Bold" />
                                                                <Setter Property="FontSize" Value="19" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsViewSwitchTarget}" Value="True">
                                                <Setter TargetName="ViewSwitchMarker"
                                                        Property="Visibility"
                                                        Value="Visible" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <WrapPanel Grid.Row="4" Margin="0,8,0,0">
                                <Button Style="{StaticResource SecondaryButton}"
                                        Content="Desvincular hoja"
                                        Command="{Binding ClearChordSheetCommand}" />
                            </WrapPanel>
                        </Grid>
                    </TabItem>
                    <TabItem Header="EDITAR TEXTO">
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBox Text="{Binding ChordSheetTextDraft, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     TextWrapping="NoWrap"
                                     AutomationProperties.AutomationId="ChordSheetEditor" />
                            <WrapPanel Grid.Row="1" Margin="0,8,0,0">
                                <Button Style="{StaticResource PrimaryButton}"
                                        Content="Procesar y guardar"
                                        Command="{Binding SaveChordSheetTextCommand}" />
                                <Button Style="{StaticResource SecondaryButton}"
                                        Content="Importar archivo"
                                        Margin="8,0,0,0"
                                        Command="{Binding ImportChordSheetCommand}" />
                            </WrapPanel>
                        </Grid>
                    </TabItem>
                    <TabItem Header="ESTRUCTURA">
                        <Grid Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding SongStructureStatus}"
                                       Foreground="{StaticResource TextSecondary}"
                                       TextWrapping="Wrap" />
                            <ListBox Grid.Row="2"
                                     ItemsSource="{Binding SongSections}"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="85" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="70" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding StartSeconds, StringFormat={}{0:0.0} s}"
                                                       FontFamily="Consolas"
                                                       Foreground="{StaticResource Accent}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Label}" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Confidence, StringFormat={}{0:P0}}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       HorizontalAlignment="Right" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</Window>
