<Window x:Class="DrumPracticeStudio.Views.PlaylistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Playlist · Drum Practice Studio" Width="900" Height="720"
        MinWidth="560" MinHeight="420" Background="{StaticResource AppBackground}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="PLAYLIST FLOTANTE" Foreground="{StaticResource Accent}"
                           FontSize="10" FontWeight="Bold" />
                <TextBlock Text="{Binding SelectedPlaylist.Name, TargetNullValue=Sin playlist}"
                           FontSize="28" FontWeight="SemiBold" Margin="0,4,0,2" />
                <TextBlock Text="{Binding SelectedPlaylistSummary}"
                           Foreground="{StaticResource TextSecondary}" />
            </StackPanel>
            <ComboBox Grid.Column="1" ItemsSource="{Binding Playlists}"
                      SelectedItem="{Binding SelectedPlaylist}" VerticalAlignment="Center"
                      AutomationProperties.AutomationId="FloatingPlaylistSelector">
                <ComboBox.ItemTemplate>
                    <DataTemplate><TextBlock Text="{Binding Name}" Foreground="#151820" /></DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Grid>

        <ListBox x:Name="FloatingPlaylistList" Grid.Row="1" Margin="0,16"
                 ItemsSource="{Binding PlaylistItems}" SelectedItem="{Binding SelectedPlaylistItem}"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.CanContentScroll="False"
                 HorizontalContentAlignment="Stretch"
                 AllowDrop="True" PreviewMouseLeftButtonDown="OnDragStart"
                 PreviewMouseMove="OnPreviewMouseMove" Drop="OnDrop"
                 PreviewMouseWheel="OnPlaylistMouseWheel"
                 MouseDoubleClick="OnItemDoubleClick"
                 AutomationProperties.AutomationId="FloatingPlaylistList">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="{StaticResource Stroke}" BorderThickness="0,0,0,1" Padding="8,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="☰" FontSize="20" Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Margin="4,0,12,0">
                                <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding AvailabilityLabel}" Foreground="{StaticResource Accent}"
                                           FontSize="11" />
                                <TextBlock Text="{Binding Detail}" Foreground="{StaticResource TextSecondary}"
                                           FontSize="10" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <WrapPanel Grid.Column="2" VerticalAlignment="Center">
                                <Button Style="{StaticResource PrimaryButton}" Content="Reproducir" Padding="10,7" Margin="0,0,6,0"
                                        Command="{Binding DataContext.PlayPlaylistItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" IsEnabled="{Binding IsAvailable}" />
                                <Button Style="{StaticResource SecondaryButton}" Content="↑" Padding="9,7" Margin="0,0,6,0"
                                        Command="{Binding DataContext.MovePlaylistItemUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" />
                                <Button Style="{StaticResource SecondaryButton}" Content="↓" Padding="9,7" Margin="0,0,6,0"
                                        Command="{Binding DataContext.MovePlaylistItemDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" />
                                <Button Style="{StaticResource SecondaryButton}" Content="Quitar" Padding="9,7"
                                        Command="{Binding DataContext.RemovePlaylistItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" />
                            </WrapPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Arrastra elementos para ordenar. También acepta pistas arrastradas desde la biblioteca."
                       Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
            <WrapPanel Grid.Column="1">
                <Button Style="{StaticResource SecondaryButton}" Content="Anterior" Padding="11,7" Margin="0,0,6,0"
                        Command="{Binding PreviousTrackCommand}" />
                <Button Style="{StaticResource PrimaryButton}" Content="Reproducir cola" Padding="11,7" Margin="0,0,6,0"
                        Command="{Binding PlayPlaylistQueueCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Content="Siguiente" Padding="11,7"
                        Command="{Binding NextTrackCommand}" />
            </WrapPanel>
        </Grid>
    </Grid>
</Window>
